  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "node src/eval/run.js",
    "eval:compare": "node src/eval/compare.js",
    "eval:list": "node src/eval/compare.js --list",
    "eval:score": "node src/eval/score.js",
    "eval:view": "node src/eval/viewer.js",
    "eval:snapshot-segments": "node scripts/snapshot-segments.js",
    "bench": "node bench/runner.js",
    "bench:compare": "node bench/compare.js",
    "bench:list": "node bench/compare.js --list",
    "test:e2e": "playwright test --config=e2e/playwright.config.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@paddleocr/paddleocr-js": "^0.3.2",
    "heic-to": "^1.4.2",
    "mammoth": "^1.12.0",
    "onnxruntime-node": "^1.24.3",
    "onnxruntime-web": "^1.25.1",
    "pdfjs-dist": "^5.7.284",
    "sentencex": "^1.0.20",
    "sentencex-wasm": "^0.1.20"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@playwright/test": "^1.59.1",
    "docx": "^9.6.1",
    "jsdom": "^29.1.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.59.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
