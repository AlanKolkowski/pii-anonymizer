{
  "name": "pii-anonymizer",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Lokalny anonimizator — offline PII anonymizer for Polish legal documents (desktop build of pii.tools)",
  "author": "Alan Kolkowski",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop:fetch-models": "node scripts/fetch-models.mjs",
    "desktop:verify-models": "node scripts/verify-models.mjs",
    "desktop:dev": "node scripts/dev-desktop.mjs",
    "desktop:build:renderer": "vite build --config vite.config.electron.js",
    "desktop:start": "electron .",
    "desktop:build": "npm run desktop:verify-models && npm run desktop:build:renderer && electron-builder --config electron-builder.yml",
    "desktop:smoke": "node e2e/desktop-smoke.mjs",
    "desktop:smoke:packaged": "node e2e/desktop-smoke.mjs --packaged",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "node src/eval/run.js",
    "eval:compare": "node src/eval/compare.js",
    "eval:list": "node src/eval/compare.js --list",
    "eval:score": "node src/eval/score.js",
    "eval:view": "node src/eval/viewer.js",
    "eval:snapshot-segments": "node scripts/snapshot-segments.js",
    "bench": "node bench/runner.js",
    "bench:compare": "node bench/compare.js",
    "bench:list": "node bench/compare.js --list",
    "test:e2e": "playwright test --config=e2e/playwright.config.js",
    "test:e2e:startup": "playwright test --config=e2e/playwright.production.config.js",
    "desktop:smoke:offline": "node e2e/desktop-smoke.mjs --packaged --offline"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@paddleocr/paddleocr-js": "^0.3.2",
    "docx": "^9.6.1",
    "heic-to": "^1.4.2",
    "mammoth": "^1.12.0",
    "onnxruntime-web": "^1.25.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "sentencex": "^1.0.20",
    "sentencex-wasm": "^0.1.20"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@napi-rs/canvas": "^0.1.100",
    "@playwright/test": "^1.59.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "onnxruntime-node": "^1.24.3",
    "onnxruntime-web-v122": "npm:onnxruntime-web@^1.22.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vscode-langservers-extracted": "^4.10.0"
  }
}
