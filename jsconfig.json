{
  "compilerOptions": {
    "checkJs": false,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": false,
    "baseUrl": "."
  },
  "include": [
    "src/**/*.js",
    "bench/**/*.js",
    "e2e/**/*.js",
    "scripts/**/*.js",
    "test-data/**/*.js",
    "vite.config.js",
    "vitest.config.js",
    "playwright.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test-data/results",
    "test-data/bench-results"
  ]
}
